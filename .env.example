# SmartThings API Configuration
# Get your Personal Access Token from: https://account.smartthings.com/tokens

SMARTTHINGS_TOKEN=your-personal-access-token-here

# Device IDs (will be determined during setup)
DEVICE_1_ID=device-uuid-1
DEVICE_1_LABEL=Device 1

DEVICE_2_ID=device-uuid-2
DEVICE_2_LABEL=Device 2
