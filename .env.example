# SmartThings Humidity Monitor Configuration

# =============================================================================
# OAuth 2.0 Authentication (Recommended)
# =============================================================================
# Get these from Samsung Developer Workspace: https://developer.smartthings.com/docs/api/public#section/Authentication
# 1. Create a SmartThings app in the Developer Workspace
# 2. Set the redirect URI to match SMARTTHINGS_REDIRECT_URI below
# 3. Copy the Client ID and Client Secret

SMARTTHINGS_CLIENT_ID=your-client-id-here
SMARTTHINGS_CLIENT_SECRET=your-client-secret-here
SMARTTHINGS_REDIRECT_URI=http://localhost:8501

# =============================================================================
# Legacy Personal Access Token (Alternative)
# =============================================================================
# If OAuth is not configured, you can use a Personal Access Token (PAT)
# Note: PATs expire after 24 hours
# Get one from: https://account.smartthings.com/tokens

SMARTTHINGS_TOKEN=your-personal-access-token-here

# =============================================================================
# Device Configuration
# =============================================================================
# Run `python discover_devices.py` to find your device IDs and labels

DEVICE_1_ID=device-uuid-1
DEVICE_1_LABEL=Device 1

DEVICE_2_ID=device-uuid-2
DEVICE_2_LABEL=Device 2
