# PuerHumidity Configuration
# Copy this file to .env and fill in the values.

# =============================================================================
# Flask
# =============================================================================
SECRET_KEY=dev-secret-key             # Any value for local dev; required in production

# =============================================================================
# Storage
# =============================================================================
STORAGE_TYPE=local                    # 'local' for dev, 'azure' for production
LOCAL_DATA_PATH=data/readings.csv     # Path for local CSV storage (dev only)

# Azure Table Storage (production — uses Managed Identity, not connection strings)
# AZURE_STORAGE_ACCOUNT_NAME=sthobbyshared
# AZURE_TABLE_NAME=sensorreadings
